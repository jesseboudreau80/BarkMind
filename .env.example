# BarkMind Environment Configuration
# Copy to .env and fill in values before starting

# ─── Governance Identity ──────────────────────────────────────────────────────
APP_NAME=barkmind
APP_VERSION=1.0.0
ENVIRONMENT=local
OWNER=jesse
DOCTRINE_VERSION=2026-05-10

# ─── Ports (canonical) ───────────────────────────────────────────────────────
BACKEND_PORT=8108
FRONTEND_PORT=3008

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://barkmind_user:changeme@127.0.0.1:5432/barkmind

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ─── Media Storage ───────────────────────────────────────────────────────────
MEDIA_BACKEND=local
MEDIA_ROOT=./media

# S3/R2 (used when MEDIA_BACKEND=s3)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=

# ─── AI / OpenClaw ───────────────────────────────────────────────────────────
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_MODEL=claude-sonnet-4-6

# ─── Aegis Governance ────────────────────────────────────────────────────────
AEGIS_BASE_URL=http://127.0.0.1:8102
AEGIS_USER_EMAIL=admin@dpvet.com

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://barkmind-api.jesseboudreau.com

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
