# BarkMind — Local Dev Environment
APP_NAME=barkmind
APP_VERSION=1.0.0
ENVIRONMENT=local
OWNER=jesse
DOCTRINE_VERSION=2026-05-10

BACKEND_PORT=8108
FRONTEND_PORT=3008

DATABASE_URL=postgresql+asyncpg://barkmind_user:barkmind_dev_password@127.0.0.1:5432/barkmind

JWT_SECRET=barkmind-local-dev-secret-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

MEDIA_BACKEND=local
MEDIA_ROOT=./media

OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_MODEL=claude-sonnet-4-6

AEGIS_BASE_URL=http://127.0.0.1:8102
AEGIS_USER_EMAIL=admin@dpvet.com

NEXT_PUBLIC_API_URL=https://barkmind-api.jesseboudreau.com

LOG_LEVEL=INFO
SERVICE_API_KEY=barkmind-service-key-change-in-production
